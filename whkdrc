.shell pwsh
# .shell powershell

# Reload whkd configuration
# alt + o                 : taskkill /f /im whkd.exe && start /b whkd # if shell is cmd
alt + o                   : Get-Process whkd | kill; Start-Process whkd -WindowStyle hidden && New-BurntToastNotification -Text "Komorebic", "Restart whkd" -AppLogo $false
# if shell is pwsh / powershell
# alt + shift + o         : komorebic reload-configuration

# alt + i                 : New-BurntToastNotification -Text "Komorebic", "Restart whkd" -AppLogo $false

# App shortcuts - these require shell to be pwsh / powershell
# The apps will be focused if open, or launched if not open

# needed ? can just do win + 2
alt + f                 : if ($wshell.AppActivate('Librewolf') -eq $False) { start librewolf }
